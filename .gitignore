# --- Базові налаштування Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --- Віртуальні середовища (КРИТИЧНО) ---
# Ігноруємо папку з бібліотеками, бо вони важать гігабайти
venv/
.venv/
env/
ENV/
bin/
lib/
include/

# --- Django ---
db.sqlite3
db.sqlite3-journal
*.log
local_settings.py

# --- Медіа та тимчасові файли ---
# Ігноруємо фото користувачів та кадри з камери
media/temp_captures/*
media/users/*
media/uploads/*
# Дозволяємо Git бачити саму папку media, якщо там є .gitkeep
!media/.gitkeep

# --- Моделі штучного інтелекту (КРИТИЧНО) ---
# Ігноруємо важкі ваги ArcFace та інших моделей
*.h5
*.pb
*.weights
*.pyd

# --- IDE та ОС ---
.vscode/
.idea/
.history/
Thumbs.db
desktop.ini

# --- Статика ---
# ПРИМІТКА: Ми НЕ ігноруємо /static/, якщо там твої стилі (CSS/JS)
# Якщо ти хочеш ігнорувати лише зібрану статику, використовуй:
# staticfiles/